# Azure AI Foundry — copy to .env.local and fill in.
# .env.local is gitignored; never commit real values.

# Project endpoint from the Azure AI Foundry portal (ai.azure.com).
AZURE_AI_PROJECT_ENDPOINT=

# The deployed model name.
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o-mini

# Auth: prefer keyless (DefaultAzureCredential via Entra). For a hackathon,
# an API key is fine — uncomment and set if not using DefaultAzureCredential.
# AZURE_AI_API_KEY=
